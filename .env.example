# Supabase (frontend — anon key, protegida por RLS)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# Stripe (backend — api/)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Supabase (backend — service role, NUNCA en frontend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Resend (backend — api/)
RESEND_API_KEY=re_...

# URL pública de la app (opcional)
NEXT_PUBLIC_URL=https://fastrevenue.app

# Upstash Redis — rate limiting distribuido (recomendado en producción)
# Crear base de datos gratuita en https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token
