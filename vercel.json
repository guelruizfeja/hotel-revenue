{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",  "value": "nosniff" },
        { "key": "X-Frame-Options",          "value": "DENY" },
        { "key": "Referrer-Policy",          "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",       "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security","value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy",  "value": "default-src 'self'; script-src 'self' https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://htkpjujfgcnxxbvwbwuw.supabase.co wss://htkpjujfgcnxxbvwbwuw.supabase.co https://api.stripe.com; img-src 'self' data: blob:; frame-src https://checkout.stripe.com; object-src 'none'; base-uri 'self'; form-action 'self';" }
      ]
    }
  ],
  "routes": [
    { "src": "/", "dest": "/landing.html" },
    { "src": "/home", "dest": "/index.html" },
    { "src": "/home/(.*)", "dest": "/index.html" },
    { "src": "/aviso-legal", "dest": "/aviso-legal.html" },
    { "src": "/privacidad", "dest": "/privacidad.html" },
    { "src": "/terminos", "dest": "/terminos.html" },
    { "src": "/cookies", "dest": "/cookies.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "status": 404, "dest": "/404.html" }
  ]
}
